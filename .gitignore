# RSR-compliant .gitignore
# SPDX-License-Identifier: PMPL-1.0-or-later
# Grumble .gitignore

# OS & Editor
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# Elixir / Erlang
server/_build/
server/deps/
server/cover/
server/*.ez
server/.elixir_ls/
# Server generated static (NOT the MVP index.html)
server/priv/static/assets/
server/priv/static/cache_manifest.json
server/priv/repo/*.lock

# ReScript
client/web/node_modules/
client/web/lib/
client/web/src/**/*.res.mjs
client/web/.cache/

# Deno
client/web/deno.lock

# Desktop (Tauri)
client/desktop/target/
client/desktop/src-tauri/target/

# Zig FFI build artifacts
ffi/zig/zig-out/
ffi/zig/zig-cache/
ffi/zig/.zig-cache/
server/priv/burble_coprocessor.*

# Idris2 build artifacts
src/abi/build/
**/*.ibc

# Build
dist/
*.beam

# Environment (NEVER commit secrets)
.env
.env.local
.env.production
erl_crash.dump


# Dependencies
/node_modules/
/vendor/
/deps/
/.elixir_ls/


# Rust

# Cargo.lock  # Keep for binaries


# Elixir
/cover/
/doc/
*.ez
erl_crash.dump


# Julia
*.jl.cov
*.jl.mem
/Manifest.toml


# Python (SaltStack only)
__pycache__/
*.py[cod]
.venv/


# Ada/SPARK
*.ali
/obj/
/bin/


# Haskell
/.stack-work/
/dist-newstyle/


# Chapel
*.chpl.tmp.*


# Secrets
.env
.env.*
*.pem
*.key
secrets/


# Test/Coverage
/coverage/
htmlcov/


# Logs
*.log
/logs/


# Machine-readable locks
.machine_readable/.locks/


# Temp
/tmp/
*.tmp
*.bak